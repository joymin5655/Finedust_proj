{
  "name": "airlens",
  "version": "3.0.0",
  "description": "AirLens — Global Air Quality Intelligence Platform",
  "scripts": {
    "dev": "bash serve_local.sh",
    "fetch:waqi": "node scripts/fetch-waqi-data.js",
    "fetch:openaq": "python3 scripts/python/fetch_openaq.py",
    "fetch:earthdata": "python3 scripts/python/fetch_earthdata_aod.py",
    "fetch:policy": "python3 scripts/python/build_policy_effect.py",
    "fetch:all": "npm run fetch:waqi && npm run fetch:openaq && npm run fetch:earthdata && npm run fetch:policy"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joymin5655/AirLens.git"
  },
  "keywords": [
    "air-quality",
    "pm25",
    "visualization",
    "policy-analysis",
    "satellite",
    "environmental-data"
  ],
  "author": "AirLens Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0"
  }
}
